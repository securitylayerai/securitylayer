{
  "name": "@securitylayer/web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless --force $(git branch --show-current | sed 's|.*/||') vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "lint": "eslint .",
    "format": "biome format --write .",
    "check-types": "tsc --noEmit",
    "check": "biome check --write . && bun run lint && bun run check-types",
    "db": "drizzle-kit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply securitylayer --local",
    "db:migrate:prod": "wrangler d1 migrations apply securitylayer --remote",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "echo 'Use wrangler d1 execute with your own seed SQL file.'",
    "deps": "bunx taze@latest -Ilw",
    "deps:major": "bunx taze@latest major -Ilw",
    "ui": "bunx shadcn@latest",
    "auth:secret": "bunx @better-auth/cli@latest secret",
    "auth:generate": "bunx @better-auth/cli@latest generate --config ./src/lib/auth/auth.ts --y --output ./src/lib/db/schema/auth.schema.ts && biome format --write ./src/lib/db/schema/auth.schema.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@fontsource/ibm-plex-mono": "^5.2.6",
    "@phosphor-icons/react": "^2.1.10",
    "@t3-oss/env-core": "^0.13.10",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.159.4",
    "@tanstack/react-router-ssr-query": "^1.159.4",
    "@tanstack/react-start": "^1.159.4",
    "@types/mdx": "^2.0.13",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "fumadocs-core": "^16.6.0",
    "fumadocs-mdx": "^14.2.7",
    "fumadocs-ui": "^16.6.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^3.8.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.13.5",
    "@eslint-react/eslint-plugin": "^2.12.2",
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/devtools-vite": "^0.5.1",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@tanstack/eslint-plugin-router": "^1.155.0",
    "@tanstack/react-devtools": "^0.9.5",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router-devtools": "^1.159.4",
    "@types/node": "^24.10.12",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^8.0.0-beta.13",
    "wrangler": "^4.46.0"
  }
}
