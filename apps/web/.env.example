VITE_BASE_URL=http://localhost:3000

# D1 is configured via `wrangler.jsonc` binding (SECURITYLAYER_DB).
# Update `database_id` there after creating your database:
# wrangler d1 create securitylayer

# bun run auth:secret
BETTER_AUTH_SECRET="ed3534f80bc8f229275ba3f59a848a12f5dfdeb4596cd4738c5e50760b51850e"

# OAuth2 providers, optional, update as needed
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NOTE:
# In your OAuth2 apps, set callback/redirect URIs to`http://localhost:3000/api/auth/callback/<provider>`
# e.g. http://localhost:3000/api/auth/callback/github
